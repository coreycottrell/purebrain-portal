# Secrets
.env
.portal-token

# Python
__pycache__/
*.pyc

# Databases (contain user data)
*.db
*.db.bak-*

# Logs
*.log
*.log.*.gz
portal.log.*

# Backups
*.bak
*.bak-*

# Temp/patch scripts
_fix_*.py
_patch_*.py
_portal_tail.py
_run_patches.sh
_validate_and_restart.sh
apply_*.py
apply_*.sh
patch_portal.py
deploy_*.sh

# Runtime data
*.jsonl
scheduled_tasks.json
user-settings.json

# Uploads
portal_uploads/

# Personal/sensitive config (use *.example.json templates instead)
portal_owner.json
investor_config.json

# Runtime bookmarks (use [] default)
bookmarks.json

# Additional backup patterns
*.bak.*
*.bak_*
*.task*-backup-*
*.mvp-backup-*
release_notes.json.local
run_portal_patch.sh

# CIV-specific custom overlay files (not tracked)
custom/config.json
custom/routes.py
custom/startup.py
custom/quickfire.json
custom/panels/*.html
custom/__pycache__/
# Track templates and scaffolding
!custom/.gitkeep
!custom/README.md
!custom/*.template
!custom/panels/.gitkeep
!custom/panels/*.template
